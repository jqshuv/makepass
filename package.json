{
  "name": "makepass",
  "version": "1.3.0",
  "description": "A very simple password generator for the command line.",
  "license": "MIT",
  "author": "Joshua Schmitt <me@jqshuv.com>",
  "repository": "https://github.com/jqshuv/makepass",
  "keywords": [],
  "private": false,
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "makepass": "build/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir build --target node",
    "start": "bun run build/index.js",
    "dev": "bun run src/index.ts",
    "compile": "bun build ./src/index.ts --compile --outfile makepass"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
